---
import backButton from "../assets/back-button.svg";
const { frontmatter } = Astro.props;
const title = frontmatter.title;
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <div id="content">
            <a id="backButton" href="/projects">
                <img src={backButton.src} width="25px">
            </a>
            <h1 id="title">{title}</h1>
            <hr>
            <section id="links">
                <a href={frontmatter.github} target="_blank">Github →</a>
            </section>
            <slot />
        </div>
    </body>
</html>

<style is:global>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
        display: flex;
        justify-content: center;
        font-family: Arial, Helvetica, sans-serif;
        background-color: #161616;
        color: #d9d9d9;
    }

    h1 {
        font-size: 2.5rem;
        margin-top: 5px;
        margin-bottom: 0px;
    }

    p {
        font-size: 1.1rem;
        margin-top: 4rem;
    }

    #backButton {
        display: block;
        position: absolute;
    }

    #backButton img {
        filter: invert(100%)
    }

    #content {
        text-align: center;
        margin-top: 25px;
    }

    #title {
        font-size: 3.5rem;
    }

    #links a {
        color: #d9d9d9;
        font-size: 1.05rem;
    }
</style>

